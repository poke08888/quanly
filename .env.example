# ─────────────────────────────────────────────────────────────────────────────
# Frontend (Vite) — copy to .env. Prefix VITE_ is exposed to the browser.
# ─────────────────────────────────────────────────────────────────────────────

# Data source per platform: "mock" (default) or "api" (real connector via BFF).
VITE_TIKTOK_SOURCE=mock
VITE_SHOPEE_SOURCE=mock

# Base URL of the backend BFF the connectors fetch from.
VITE_TIKTOK_BFF_URL=http://localhost:8790
VITE_SHOPEE_BFF_URL=http://localhost:8790

# ─────────────────────────────────────────────────────────────────────────────
# Backend BFF (server/) — SERVER-ONLY. Never exposed to the browser (no VITE_).
# app_secret / access_token must NEVER reach the frontend.
# ─────────────────────────────────────────────────────────────────────────────

# Master key used to ENCRYPT shop credentials at rest (AES-256-GCM) in the SQLite
# store. REQUIRED before storing real credentials — if unset, an insecure dev key
# is used (loud warning). Use a long random string; changing it makes previously
# stored credentials undecryptable (re-enter them in the "Thương hiệu & Shop" screen).
APP_SECRET_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Brands + shops are now managed in the app (CEO → "Thương hiệu & Shop" screen):
# each shop stores its own credentials + sample|live mode in the DB. The TIKTOK_* /
# SHOPEE_* / *_MODE vars below are LEGACY — kept for reference only; the fetch layer
# no longer reads them (credentials come from the per-shop store).
# ─────────────────────────────────────────────────────────────────────────────

# LEGACY (no longer used by the fetch layer — configure mode per shop in the UI).
TIKTOK_MODE=sample
SHOPEE_MODE=sample

# --- TikTok Shop Partner API v2 (Analytics + Finance -> daily-series) ---
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_SHOP_CIPHER=
TIKTOK_BASE_URL=https://open-api.tiktokglobalshop.com

# --- TikTok API for Business / Marketing API (Ads -> campaigns + daily ad spend) ---
# DIFFERENT API from the Partner API above: no HMAC signing, header Access-Token
# + advertiser_id query param. Reuses TIKTOK_MODE (sample|live).
TIKTOK_BIZ_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=
TIKTOK_BIZ_BASE_URL=https://business-api.tiktok.com

# --- Shopee Open API v2 (Order + Escrow -> daily-series) ---
# DIFFERENT signing from TikTok: sign = HMAC_SHA256(partner_key,
#   partner_id + api_path + timestamp + access_token + shop_id), lowercase hex.
# Sandbox base: https://partner.test-stable.shopeemobile.com
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_ACCESS_TOKEN=
SHOPEE_SHOP_ID=
SHOPEE_BASE_URL=https://partner.shopeemobile.com

# BFF port (VITE_TIKTOK_BFF_URL / VITE_SHOPEE_BFF_URL must match).
PORT=8790
